.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.favorites-list {
  padding-bottom: 20rpx;
}

.favorite-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.favorite-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.favorite-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.favorite-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.favorite-desc {
  font-size: 24rpx;
  color: #999;
}

.favorite-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.favorite-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.remove-btn {
  padding: 8rpx 24rpx;
  border: 1rpx solid #ff4d4f;
  color: #ff4d4f;
  border-radius: 30rpx;
  font-size: 24rpx;
}
