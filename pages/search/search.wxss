.search-header {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 30rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.results {
  padding-bottom: 20rpx;
}

.result-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.result-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
}

.result-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.history {
  padding: 20rpx;
}

.history-header {
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
}

.history-item {
  padding: 16rpx 32rpx;
  margin: 0 16rpx 16rpx 0;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}
