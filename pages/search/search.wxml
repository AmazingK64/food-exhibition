<view class="container">
  <view class="search-header">
    <input 
      class="search-input" 
      placeholder="搜索菜品..." 
      value="{{keyword}}"
      bindinput="onInput"
      bindconfirm="onSearch"/>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <view wx:if="{{results.length > 0}}" class="results">
    <view 
      wx:for="{{results}}" 
      wx:key="_id"
      class="result-item"
      bindtap="onFoodTap"
      data-id="{{item._id}}">
      <image class="result-image" src="{{item.image}}" mode="aspectFill"/>
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <text class="result-desc">{{item.description}}</text>
        <text class="result-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{keyword && !searching}}" class="empty">
    <text>未找到相关菜品</text>
  </view>

  <view wx:elif="{{history.length > 0 && !keyword}}" class="history">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
    </view>
    <view class="history-list">
      <view 
        wx:for="{{history}}" 
        wx:key="*this"
        class="history-item"
        bindtap="onHistoryTap"
        data-keyword="{{item}}">
        {{item}}
      </view>
    </view>
  </view>
</view>
