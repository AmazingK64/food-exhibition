.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.container {
  padding: 0 0 200rpx 0;
}

.image-wrapper {
  position: relative;
}

.dish-image-swiper {
  width: 100%;
  height: 500rpx;
}

.dish-image {
  width: 100%;
  height: 100%;
}

.image-nav-btn {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.image-nav-btn text {
  color: #fff;
  font-size: 24rpx;
}

.image-actions {
  position: absolute;
  left: 30rpx;
  bottom: 30rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.action-btn text {
  color: #fff;
  font-size: 24rpx;
}

.delete-btn {
  background: rgba(255, 77, 79, 0.8);
}

.upload-btn {
  position: absolute;
  right: 30rpx;
  top: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.upload-btn text {
  color: #fff;
  font-size: 24rpx;
}

.upload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-overlay text {
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 8rpx;
}

.dish-header {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx 20rpx;
}

.dish-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.dish-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.favorite-btn {
  padding: 10rpx;
  font-size: 40rpx;
}

.dish-tags {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-price {
  font-size: 40rpx;
  color: #ff6b35;
  font-weight: bold;
}

.section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.dish-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.ingredients-list {
  display: flex;
  flex-wrap: wrap;
}

.ingredient-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin: 0 16rpx 16rpx 0;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.steps-list {
  display: flex;
  flex-direction: column;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-bar .btn {
  width: 80%;
  text-align: center;
  padding: 24rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  margin: 0 auto;
}

page {
  background: #f5f5f5;
}
