.container {
  padding: 30rpx;
  background: #f8f8f8;
  min-height: 100vh;
}

.content {
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}

.h2 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 40rpx 0 24rpx 0;
  padding-left: 20rpx;
  border-left: 8rpx solid #ff6b35;
  line-height: 1.4;
}

.h3 {
  font-size: 32rpx;
  font-weight: bold;
  color: #555;
  margin: 32rpx 0 16rpx 0;
  line-height: 1.4;
}

.p {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  margin: 16rpx 0;
  text-align: justify;
}

.ul {
  margin: 16rpx 0;
}

.li {
  display: flex;
  align-items: flex-start;
  margin: 12rpx 0;
  padding-left: 10rpx;
}

.bullet {
  color: #ff6b35;
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.li-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

.ol {
  margin: 16rpx 0;
  padding-left: 20rpx;
}

.ol .li {
  padding-left: 0;
  list-style-type: decimal;
  list-style-position: inside;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}
