<view class="container">
  <view class="header">
    <view class="title">{{name}}</view>
    <view class="meta">
      <text class="category">{{category}}</text>
      <text class="difficulty">难度: {{difficulty}}</text>
    </view>
  </view>
  
  <view class="content" wx:if="{{isAuthorized && isAdmin && !loading}}">
    <block wx:for="{{content}}" wx:key="index">
      <view wx:if="{{item.type === 'h2'}}" class="h2">{{item.text}}</view>
      <view wx:elif="{{item.type === 'h3'}}" class="h3">{{item.text}}</view>
      <view wx:elif="{{item.type === 'p'}}" class="p">{{item.text}}</view>
      <view wx:elif="{{item.type === 'ul'}}" class="ul">
        <view wx:for="{{item.items}}" wx:for-index="liIdx" wx:for-item="li" wx:key="liIdx" class="li">
          <text class="bullet">•</text>
          <text class="li-text">{{li}}</text>
        </view>
      </view>
      <view wx:elif="{{item.type === 'ol'}}" class="ol">
        <view wx:for="{{item.items}}" wx:for-index="liIdx" wx:for-item="li" wx:key="liIdx" class="li">
          <text class="li-text">{{li}}</text>
        </view>
      </view>
    </block>
  </view>
  <view wx:elif="{{isAuthorized && !isAdmin && !loading}}" class="auth-prompt">
    <view class="auth-icon">🔒</view>
    <view class="auth-text">仅管理员可见</view>
  </view>
  <view wx:elif="{{!isAuthorized}}" class="loading">请先授权登录</view>
  <view wx:else class="loading">加载中...</view>
</view>
