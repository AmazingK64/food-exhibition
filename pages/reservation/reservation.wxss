.container {
  overflow-x: hidden;
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

page {
  overflow-x: hidden;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  margin-bottom: 120rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.time-list {
  display: flex;
  flex-wrap: wrap;
}

.time-item {
  padding: 16rpx 32rpx;
  margin: 0 16rpx 16rpx 0;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.time-item.active {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  color: #fff;
  border-color: #ff6b35;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-bar .btn {
  width: 80%;
  text-align: center;
  padding: 24rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
}

.submit-bar .btn.disabled {
  opacity: 0.6;
}

.selected-dishes {
  display: flex;
  flex-wrap: wrap;
}

.dish-tag {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fff7e0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #fa8c16;
  margin: 0 16rpx 16rpx 0;
}

.dish-remove {
  margin-left: 8rpx;
  color: #ff4d4f;
  font-size: 32rpx;
}

.dish-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border: 1rpx dashed #ff6b35;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #ff6b35;
}

.dish-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.dish-picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.dish-picker-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.dish-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dish-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dish-picker-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.dish-picker-list {
  flex: 1;
  padding: 20rpx;
  max-height: 60vh;
}

.dish-picker-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #f9f9f9;
}

.dish-picker-item.selected {
  background: #fff7e0;
  border: 1rpx solid #fa8c16;
}

.dish-picker-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.dish-picker-info {
  flex: 1;
}

.dish-picker-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.dish-picker-price {
  font-size: 26rpx;
  color: #ff6b35;
}

.dish-picker-check {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fa8c16;
}

.dish-picker-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}
