<view class="container">
  <view class="form-card">
    <view class="form-title">{{isEdit ? '修改预约' : '预约信息'}}</view>

    <view class="form-item">
      <text class="form-label">已选菜品</text>
      <view class="selected-dishes">
        <view 
          wx:for="{{selectedDishes}}" 
          wx:key="id"
          class="dish-tag">
          {{item.name}}
          <text class="dish-remove" catchtap="onRemoveDish" data-index="{{index}}">×</text>
        </view>
        <view class="dish-add" bindtap="onAddDish">+ 添加菜品</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">姓名</text>
      <input 
        class="form-input" 
        placeholder="请输入您的姓名" 
        value="{{userName}}"
        bindinput="onNameInput"/>
    </view>

    <view class="form-item">
      <text class="form-label">预约日期</text>
      <picker mode="date" bindchange="onDateInput">
        <view class="picker">
          {{visitDate || '请选择日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">预约时间</text>
      <view class="time-list">
        <view 
          wx:for="{{times}}" 
          wx:key="*this"
          class="time-item {{time === item ? 'active' : ''}}"
          bindtap="onTimeSelect"
          data-time="{{item}}">
          {{item}}
        </view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea 
        class="form-textarea" 
        placeholder="请输入备注信息（可选）"
        value="{{note}}"
        bindinput="onNoteInput"/>
    </view>
  </view>

  <view class="submit-bar">
    <view 
      class="btn btn-primary {{submitting ? 'disabled' : ''}}" 
      bindtap="onSubmit">
      {{submitting ? '提交中...' : (isEdit ? '保存修改' : '确认预约')}}
    </view>
  </view>
</view>

<view class="dish-picker-modal" wx:if="{{showDishPicker}}">
  <view class="dish-picker-mask" bindtap="onCloseDishPicker"></view>
  <view class="dish-picker-content">
    <view class="dish-picker-header">
      <text class="dish-picker-title">选择菜品</text>
      <text class="dish-picker-close" bindtap="onCloseDishPicker">×</text>
    </view>
    <scroll-view scroll-y class="dish-picker-list">
      <view 
        wx:for="{{allDishes}}" 
        wx:key="_id"
        class="dish-picker-item {{selectedDishIds.includes(item._id) ? 'selected' : ''}}"
        bindtap="onToggleDish"
        data-id="{{item._id}}"
        data-name="{{item.name}}">                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
        <image class="dish-picker-image" src="{{item.image}}" mode="aspectFill"/>
        <view class="dish-picker-info">
          <text class="dish-picker-name">{{item.name}}</text>
          <text class="dish-picker-price">¥{{item.price}}</text>
        </view>
        <view class="dish-picker-check">
          <text wx:if="{{selectedDishIds.includes(item._id)}}">✓</text>
        </view>
      </view>
    </scroll-view>
    <view class="dish-picker-footer">
      <view class="btn btn-primary" bindtap="onConfirmDishPicker">确定</view>
    </view>
  </view>
</view>
