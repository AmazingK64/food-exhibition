.container {
  min-height: 100vh;
  background: #f8f8f8;
}

.header {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.search-input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  margin-left: 20rpx;
  padding: 15rpx 30rpx;
  background: #ff6b35;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  gap: 16rpx;
}

.filter-item {
  flex: 1;
}

.filter-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.filter-picker .arrow {
  font-size: 20rpx;
  color: #999;
}

.filter-reset {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.recipe-card {
  width: calc(50% - 60rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.recipe-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.recipe-difficulty {
  display: block;
  font-size: 22rpx;
  color: #ff6b35;
}

.recipe-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recipe-category {
  font-size: 22rpx;
  color: #999;
}

.section-title .count {
  margin-left: 16rpx;
  color: #ff6b35;
  font-weight: 500;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx 0;
}
