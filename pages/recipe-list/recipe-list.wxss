.container {
  min-height: 100vh;
  background: #f8f8f8;
}

.header {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #ff6b35;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #ff6b35;
  border-radius: 3rpx;
}

.tab-content {
  padding: 30rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.difficulty-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.difficulty-item {
  width: calc(50% - 16rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.difficulty-item:nth-child(odd) {
  margin-right: 32rpx;
}

.difficulty-item.selected {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
}

.difficulty-item .star {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.difficulty-item .label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

.difficulty-item.selected .label {
  color: #fff;
}

.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.recipe-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.recipe-name {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.recipe-difficulty {
  display: block;
  font-size: 22rpx;
  color: #ff6b35;
}

.category-scroll-view {
  height: calc(100vh - 300rpx);
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.category-name {
  font-size: 30rpx;
  color: #333;
}

.category-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.category-item.selected {
  background: linear-gradient(135deg, #ff6b35, #ff8c42);
}

.category-item.selected .category-name,
.category-item.selected .category-arrow {
  color: #fff;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 60rpx 0;
}
